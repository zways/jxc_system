APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# 邮件发送（找回密码等）
# MAIL_MAILER: smtp=真实发信 | log=仅写日志（开发默认）
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
# 加密：465 端口可不设（自动 SSL）；阿里云用 80 端口时设 MAIL_SCHEME=smtp
# MAIL_SCHEME=smtp
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------- 国内第三方邮件服务示例 ----------
# 阿里云邮件推送（DirectMail）：控制台开通后创建发信域名/发信地址，获取 SMTP 密码
# MAIL_MAILER=smtp
# MAIL_HOST=smtpdm.aliyun.com
# MAIL_PORT=465
# MAIL_USERNAME=发信地址（如 no-reply@mail.你的域名.com）
# MAIL_PASSWORD=SMTP 密码（控制台生成）
# MAIL_FROM_ADDRESS=与 MAIL_USERNAME 一致
# MAIL_FROM_NAME=进销存系统

# 腾讯云 SES：控制台创建发信域名与发信地址，获取 SMTP 密码
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.qcloudmail.com
# MAIL_PORT=465
# MAIL_USERNAME=发信地址
# MAIL_PASSWORD=SMTP 密码
# MAIL_FROM_ADDRESS=与 MAIL_USERNAME 一致
# MAIL_FROM_NAME=进销存系统

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# 找回密码功能：是否允许用户通过邮箱找回密码（true/false），关闭后登录页不显示“忘记密码”入口
PASSWORD_RESET_ENABLED=true
# 前端应用地址，用于邮件中的重置链接（若不设置则使用 APP_URL）
# FRONTEND_URL=https://your-frontend.domain.com

# 支付系统（未开启时支持后台线下付款，管理员手动为企业续费/改套餐）
# PAYMENT_ENABLED=false
# PAYMENT_PROVIDER=alipay
# 支付宝（公钥模式）
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY= 应用私钥 PEM 内容或 file:// 路径
# ALIPAY_PUBLIC_KEY= 支付宝公钥
# ALIPAY_NOTIFY_URL=https://your-domain.com/api/v1/payment/notify/alipay
# ALIPAY_RETURN_URL=https://your-domain.com/tenant-profile
# ALIPAY_SANDBOX=true
# 微信支付（Native 扫码）
# WECHAT_PAY_APP_ID=
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_API_V3_KEY=
# WECHAT_PAY_MERCHANT_PRIVATE_KEY= PEM 内容或 file:// 路径
# WECHAT_PAY_MERCHANT_SERIAL_NO= 商户证书序列号
# WECHAT_PAY_PLATFORM_PUBLIC_KEY_ID= 微信支付公钥 ID
# WECHAT_PAY_PLATFORM_PUBLIC_KEY= 微信支付公钥 PEM 或 file:// 路径
# WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/v1/payment/notify/wechat
